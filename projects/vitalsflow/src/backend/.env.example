# Copy this file to .env and fill in real values.
# Never commit .env — it is listed in .gitignore.

# ── Gemini ───────────────────────────────────────────────────────────────────
# Get your key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: override model (default is gemini-1.5-flash)
# GEMINI_MODEL=gemini-1.5-flash

# Set to false to skip LLM and run deterministic NEWS2 only (useful for dev)
# USE_LLM=true

# ── FHIR ─────────────────────────────────────────────────────────────────────
# Public HAPI FHIR R4 server — no auth required for hackathon
FHIR_BASE_URL=http://hapi.fhir.org/baseR4

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# CORS_ORIGINS=http://localhost:3000,https://vitalsflow.vercel.app

# ── Logging ──────────────────────────────────────────────────────────────────
# LOG_LEVEL=INFO
