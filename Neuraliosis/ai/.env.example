# OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# ChromaDB
CHROMA_PERSIST_DIR=./chroma_db

# FastAPI
API_HOST=0.0.0.0
API_PORT=8000

# Logging
LOG_LEVEL=INFO

# Model settings
LLM_MODEL=gpt-4o
CHEAP_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# Confidence threshold
CONFIDENCE_THRESHOLD=0.65
MAX_QUESTIONS=4
